# Required. Use the exact Search Console property URL, for example:
# https://example.com/ or sc-domain:example.com
SITE_URL=https://example.com/

# Required for direct Google login. For scheduled jobs, a saved browser
# state file is usually more reliable than logging in on every run.
GOOGLE_EMAIL=person@example.com
GOOGLE_PASSWORD=change-me

# Required. Add the Search Console report page to scrape.
# Use either a full Search Console report URL, or a real value after item_key= if the URL has one.
GSC_REPORTS_JSON=[{"category":"Indexing","name":"Pages","param":"https://search.google.com/search-console/index?resource_id=sc-domain%3Aexample.com"}]

# Optional Playwright settings.
PLAYWRIGHT_BROWSER=chromium
# Optional. Use chrome to open installed Google Chrome instead of bundled Chromium.
# PLAYWRIGHT_CHANNEL=chrome
# Optional Chromium login workaround for Google's "browser or app is not secure" page.
PLAYWRIGHT_DISABLE_AUTOMATION_CONTROLLED=true
# Optional. Set a current desktop Chrome user agent if Google still rejects login.
# PLAYWRIGHT_USER_AGENT=Mozilla/5.0 (...)
# If Google says the browser is not secure during login, use:
# PLAYWRIGHT_BROWSER=firefox
# and leave PLAYWRIGHT_CHANNEL unset.
PLAYWRIGHT_HEADLESS=true
STORAGE_STATE_PATH=./.auth/gsc-state.json
LOGIN_TIMEOUT_MS=120000
NAVIGATION_TIMEOUT_MS=60000
GSC_REPORT_SELECTOR=.OOHai
GSC_UPDATED_SELECTOR=.zTJZxd.zOPr2c

# Optional report window used for output filenames.
START_DATE=2026-04-20
END_DATE=2026-04-27

# Optional local output path for CLI/local testing.
OUTPUT_FILE=./reports/gsc-report.csv

# Optional cloud output targets. Set one of these for scheduled cloud jobs.
# GCS_BUCKET=my-gcs-bucket
# GCS_PREFIX=gsc-reports
# S3_BUCKET=my-s3-bucket
# S3_PREFIX=gsc-reports
