# Required. Use the exact Search Console property URL, for example:
# https://example.com/ or sc-domain:example.com
SITE_URL=sc-domain:search-control-property.com

# Required for direct Google login. For scheduled jobs, a saved browser
# state file is usually more reliable than logging in on every run.
GOOGLE_EMAIL=webmasters-email@gmail.com
GOOGLE_PASSWORD=GOOGLE_PASSWORD_HERE
# Required. Add the report drilldown item_key values to scrape.
# Open the report in Search Console and copy the value after item_key= from the URL.
GSC_REPORTS_JSON=[{"category":"Indexing","name":"Pages drilldown","param":"ITEM_KEY_HERE"}]



# Optional report window. If omitted, the job exports the last 7 complete days.
START_DATE=2026-04-20
END_DATE=2026-04-27

# Optional Search Analytics dimensions.
REPORT_DIMENSIONS=query,page,country,device

# Optional filters. JSON array in the Search Console API dimensionFilterGroups shape.
# DIMENSION_FILTER_GROUPS=[{"filters":[{"dimension":"country","operator":"equals","expression":"usa"}]}]

# Optional row limit.
ROW_LIMIT=25000

# Optional local output path for CLI/local testing.
OUTPUT_FILE=./reports/gsc-report.csv

# Optional cloud output targets. Set one of these for scheduled cloud jobs.
# GCS_BUCKET=my-gcs-bucket
# GCS_PREFIX=gsc-reports
# S3_BUCKET=my-s3-bucket
# S3_PREFIX=gsc-reports
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_CHANNEL=chrome
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_DISABLE_AUTOMATION_CONTROLLED=true

